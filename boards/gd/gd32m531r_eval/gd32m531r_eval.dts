/dts-v1/;

#include <gd/gd32m53x/gd32m531rc.dtsi>
#include "gd32m531r_eval-pinctrl.dtsi"
#include <zephyr/dt-bindings/dma/gd32_dma.h>

/ {
	model = "GigaDevice GD32M531R-EVAL";
	compatible = "gd,gd32m531r-eval";

	chosen {
		zephyr,flash = &flash0;
		zephyr,sram = &sram0;
		zephyr,console = &uart3;
		zephyr,shell-uart = &uart3;
	};

	leds {
		compatible = "gpio-leds";

		led0: led0 {
			gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;
			label = "LED0";
		};

		led1: led1 {
			gpios = <&gpiod 9 GPIO_ACTIVE_HIGH>;
			label = "LED1";
		};

		led2: led2 {
			gpios = <&gpiod 10 GPIO_ACTIVE_HIGH>;
			label = "LED2";
		};

		led3: led3 {
			gpios = <&gpiod 11 GPIO_ACTIVE_HIGH>;
			label = "LED3";
		};

		led4: led4 {
			gpios = <&gpiod 12 GPIO_ACTIVE_HIGH>;
			label = "LED4";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";

		user_key: user_key {
			gpios = <&gpioa 0 GPIO_ACTIVE_LOW>;
			label = "User Key";
		};
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		led2 = &led2;
		led3 = &led3;
		led4 = &led4;
		sw0 = &user_key;
		eeprom-0 = &eeprom0;
	};
};

&gpioa {
	status = "okay";
};

&gpiob {
	status = "okay";
};

&gpiod {
	status = "okay";
};

&gpiof {
	status = "okay";
};

&gpiog {
	status = "okay";
};

&uart0 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart0_default>;
	pinctrl-names = "default";
	dmas = <&dmamux 0 13 (GD32_DMA_PERIPH_RX | GD32_DMA_PRIORITY_HIGH)>,
	       <&dmamux 1 14 (GD32_DMA_PERIPH_TX | GD32_DMA_PRIORITY_HIGH)>;
	dma-names = "rx", "tx";
};

&uart2 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart2_default>;
	pinctrl-names = "default";
	dmas = <&dmamux 4 17 (GD32_DMA_PERIPH_RX | GD32_DMA_PRIORITY_HIGH)>,
	       <&dmamux 5 18 (GD32_DMA_PERIPH_TX | GD32_DMA_PRIORITY_HIGH)>;
	dma-names = "rx", "tx";
};

&uart3 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart3_default>;
	pinctrl-names = "default";
	dmas = <&dmamux 2 19 (GD32_DMA_PERIPH_RX | GD32_DMA_PRIORITY_HIGH)>,
	       <&dmamux 3 20 (GD32_DMA_PERIPH_TX | GD32_DMA_PRIORITY_HIGH)>;
	dma-names = "rx", "tx";
};

&spi0 {
	status = "okay";
	pinctrl-0 = <&spi0_default>;
	pinctrl-names = "default";
	cs-gpios = <&gpiod 8 GPIO_ACTIVE_LOW>;
	dmas = <&dmamux 8 21 (GD32_DMA_PERIPH_RX | GD32_DMA_PRIORITY_MEDIUM)>,
	       <&dmamux 9 22 (GD32_DMA_PERIPH_TX | GD32_DMA_PRIORITY_MEDIUM)>;
	dma-names = "rx", "tx";

	spi_flash0: gd25q16@0 {
		compatible = "jedec,spi-nor";
		size = <0x1000000>;
		reg = <0>;
		spi-max-frequency = <4000000>;
		status = "okay";
		jedec-id = [c8 40 15];
	};
};

&i2c0 {
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-names = "default";
	clock-frequency = <100000>;
	dmas = <&dmamux 6 11 (GD32_DMA_PERIPH_RX | GD32_DMA_PRIORITY_HIGH)>,
	       <&dmamux 7 12 (GD32_DMA_PERIPH_TX | GD32_DMA_PRIORITY_HIGH)>;
	dma-names = "rx", "tx";

	eeprom0: eeprom@50 {
		compatible = "atmel,at24";
		reg = <0x50>;
		status = "okay";
		size = <256>;
		pagesize = <8>;
		address-width = <8>;
		timeout = <5>;
	};
};

&dma0 {
	status = "okay";
};

&dma1 {
	status = "okay";
};

&dmamux {
	status = "okay";
};
