/*
 * Board-default SPI0 pins: PF11/SCK, PF12/MISO, PF8/MOSI, PD8/CS.
 * The on-board GD25Q16 is connected through TXS0108E level shifter.
 * No pin override needed — use board DTS defaults.
 */

&spi_flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* 64KB storage partition at the end of the 2MB flash. */
		storage_partition: partition@1f0000 {
			label = "storage";
			reg = <0x001f0000 DT_SIZE_K(64)>;
		};
	};
};
