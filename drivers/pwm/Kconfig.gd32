config PWM_GD32
	bool "GigaDevice GD32 PWM driver"
	default y
	depends on DT_HAS_GD_GD32_PWM_ENABLED
	select PINCTRL
	select USE_GD32_TIMER
	help
	  Enable the GigaDevice GD32 PWM driver.
