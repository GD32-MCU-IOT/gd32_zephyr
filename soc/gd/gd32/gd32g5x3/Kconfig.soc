config SOC_SERIES_GD32G5X3
	bool
	select SOC_FAMILY_GD_GD32
	help
	  Enable support for GigaDevice GD32G5X3 MCU series

config SOC_SERIES
	default "gd32g5x3" if SOC_SERIES_GD32G5X3

config SOC_GD32G553
	bool
	select SOC_SERIES_GD32G5X3

config SOC
	default "gd32g553" if SOC_GD32G553
