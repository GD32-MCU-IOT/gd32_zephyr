config SOC_SERIES_GD32M53X
	bool
	select SOC_FAMILY_GD_GD32
	help
	  Enable support for GigaDevice GD32M53X MCU series

config SOC_SERIES
	default "gd32m53x" if SOC_SERIES_GD32M53X

config SOC_GD32M531
	bool
	select SOC_SERIES_GD32M53X

config SOC
	default "gd32m531" if SOC_GD32M531
