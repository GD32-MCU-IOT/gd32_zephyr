config SOC_SERIES_GD32H75E
	bool
	select SOC_FAMILY_GD_GD32
	help
	  Enable support for GigaDevice GD32H75E MCU series

config SOC_SERIES
	default "gd32h75e" if SOC_SERIES_GD32H75E

config SOC_GD32H75E
	bool
	select SOC_SERIES_GD32H75E

config SOC
	default "gd32h75e" if SOC_GD32H75E
