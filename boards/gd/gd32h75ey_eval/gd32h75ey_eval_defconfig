CONFIG_BOARD_GD32H75EY_EVAL=y

CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_STDOUT_CONSOLE=y
CONFIG_SERIAL=y

CONFIG_GPIO=y
CONFIG_PWM=y

# D-cache disabled for initial bring-up to rule out cache coherency issues
# with DMA. Cortex-M7 arch enables DCACHE by default, must explicitly disable.
# Re-enable after DMA is confirmed working with proper cache management.
CONFIG_DCACHE=n
