config SOC_SERIES_GD32F30X
	bool
	select SOC_FAMILY_GD_GD32
	help
	  Enable support for GigaDevice GD32F30x MCU series

config SOC_SERIES
	default "gd32f30x" if SOC_SERIES_GD32F30X

config SOC_GD32F307
	bool
	select SOC_SERIES_GD32F30X

config SOC
	default "gd32f307" if SOC_GD32F307
